package main

import "fmt"

const NMAX int = 100

type pemilik struct {
	Nama_Pemilik string
	Nomor_hp     string
	Alamat       string
}
type kendaraan struct {
	Plat_nomor     string
	Merk_kendaraan string
	Tipe_kendaraan string
	Tahun_Produksi int
}
type Riwayat_servis struct {
	Tahun   int
	bulan   int
	tanggal int
	jenis   string
	detail  string
}

type Tab_pemilik [NMAX]pemilik
type Tab_kendaraan [NMAX]kendaraan
type Tab_Riwayat_servis [NMAX]Riwayat_servis

func main() {
	var dataPemilik Tab_pemilik
	var dataKendaraan Tab_kendaraan
	var dataService Tab_Riwayat_servis
	var i int
	var pilihan int

	for {
		fmt.Println("==== ZAIDAN AND MAGALIH OTOMOTIF ====")
		fmt.Println("Silahkan pilih layanan yang diinginkan")
		fmt.Println("1.		Input Data")
		fmt.Println("2.		Tampilkan Data")
		fmt.Println("3.		Ubah Data")
		fmt.Println("4.		Hapus Data")
		fmt.Println("5.		Tambah Riwayat Servis")
		fmt.Println("6.		Sequential Search Plat Nomor")
		fmt.Println("7.		Binary Search Plat Nomor")
		fmt.Println("8.		Selection Sort Tahun Produksi")
		fmt.Println("9.		Insertion Sort Tanggal Servis")
		fmt.Println("10.		Statistik Servis")
		fmt.Println("0.		Keluar")
		fmt.Print("Pilihan: ")
		fmt.Scan(&pilihan)

		if pilihan == 1 {
			inputData(&dataPemilik, &dataKendaraan, &dataService, &i)
		} else if pilihan == 2 {
			tampilData(dataPemilik, dataKendaraan, dataService, i)
		} else if pilihan == 3 {
			ubahData(&dataPemilik, &dataKendaraan, &dataService, i)
		} else if pilihan == 4 {
			hapusData(&dataPemilik, &dataKendaraan, &dataService, &i)
		} else if pilihan == 5 {
			tambahRiwayatServis(&dataService, dataKendaraan, i)
		} else if pilihan == 6 {
			sequentialSearch(dataKendaraan, i)
		} else if pilihan == 7 {
			binarySearch(dataKendaraan, i)
		} else if pilihan == 8 {
			selectionSort(&dataKendaraan, &dataPemilik, &dataService, i)
		} else if pilihan == 9 {
			insertionSort(&dataKendaraan, &dataPemilik, &dataService, i)
		} else if pilihan == 10 {
			statistikServis(dataService, i)
		} else if pilihan == 0 {
			fmt.Println("Terima kasih telah menggunakan JIBUNG DAN LER OTOMOTIF!")
			return
		} else {
			fmt.Println("Pilihan tidak valid!")
		}
	}
}

