func hapusData(dataPemilik *Tab_pemilik, dataKendaraan *Tab_kendaraan, dataService *Tab_Riwayat_servis, i *int) {
	var plat string
	fmt.Print("Masukkan Plat Nomor yang ingin dihapus: ")
	fmt.Scan(&plat)

	var j int
	for j = 0; j < *i; j++ {
		if (*dataKendaraan)[j].Plat_nomor == plat {
			var k int
			for k = j; k < *i-1; k++ {
				(*dataPemilik)[k] = (*dataPemilik)[k+1]
				(*dataKendaraan)[k] = (*dataKendaraan)[k+1]
				(*dataService)[k] = (*dataService)[k+1]
			}
			*i--
			fmt.Println("Data berhasil dihapus!")
			return
		}
	}
	fmt.Println("Data tidak ditemukan!")
}

