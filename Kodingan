func sequentialSearch(dataKendaraan Tab_kendaraan, i int) {
	var plat string
	fmt.Print("Masukkan Plat Nomor yang dicari: ")
	fmt.Scan(&plat)

	var j int
	for j = 0; j < i; j++ {
		if dataKendaraan[j].Plat_nomor == plat {
			fmt.Println("Data ditemukan di index", j)
			fmt.Println("Plat Nomor     :", dataKendaraan[j].Plat_nomor)
			fmt.Println("Merk Kendaraan :", dataKendaraan[j].Merk_kendaraan)
			fmt.Println("Tipe Kendaraan :", dataKendaraan[j].Tipe_kendaraan)
			fmt.Println("Tahun Produksi :", dataKendaraan[j].Tahun_Produksi)
			return
		}
	}
	fmt.Println("Data tidak ditemukan!")
}

func binarySearch(dataKendaraan Tab_kendaraan, i int) {
	var plat string
	fmt.Print("Masukkan Plat Nomor yang dicari: ")
	fmt.Scan(&plat)

	kiri := 0
	kanan := i - 1
	for kiri <= kanan {
		tengah := (kiri + kanan) / 2
		if dataKendaraan[tengah].Plat_nomor == plat {
			fmt.Println("Data ditemukan di index", tengah)
			fmt.Println("Plat Nomor     :", dataKendaraan[tengah].Plat_nomor)
			fmt.Println("Merk Kendaraan :", dataKendaraan[tengah].Merk_kendaraan)
			fmt.Println("Tipe Kendaraan :", dataKendaraan[tengah].Tipe_kendaraan)
			fmt.Println("Tahun Produksi :", dataKendaraan[tengah].Tahun_Produksi)
			return
		} else if dataKendaraan[tengah].Plat_nomor < plat {
			kiri = tengah + 1
		} else {
			kanan = tengah - 1
		}
	}
	fmt.Println("Data tidak ditemukan!")
}

func selectionSort(dataKendaraan *Tab_kendaraan, dataPemilik *Tab_pemilik, dataService *Tab_Riwayat_servis, i int) {
	var j, k int
	for j = 0; j < i-1; j++ {
		idxMin := j
		for k = j + 1; k < i; k++ {
			if (*dataKendaraan)[k].Tahun_Produksi < (*dataKendaraan)[idxMin].Tahun_Produksi {
				idxMin = k
			}
		}
		(*dataKendaraan)[j], (*dataKendaraan)[idxMin] = (*dataKendaraan)[idxMin], (*dataKendaraan)[j]
		(*dataPemilik)[j], (*dataPemilik)[idxMin] = (*dataPemilik)[idxMin], (*dataPemilik)[j]
		(*dataService)[j], (*dataService)[idxMin] = (*dataService)[idxMin], (*dataService)[j]
	}
	fmt.Println("Data berhasil diurutkan berdasarkan Tahun Produksi!")
}

func insertionSort(dataKendaraan *Tab_kendaraan, dataPemilik *Tab_pemilik, dataService *Tab_Riwayat_servis, i int) {
	var j int
	for j = 1; j < i; j++ {
		kunciKendaraan := (*dataKendaraan)[j]
		kunciPemilik := (*dataPemilik)[j]
		kunciService := (*dataService)[j]
		k := j - 1
		for k >= 0 && (*dataService)[k].Tahun > kunciService.Tahun {
			(*dataKendaraan)[k+1] = (*dataKendaraan)[k]
			(*dataPemilik)[k+1] = (*dataPemilik)[k]
			(*dataService)[k+1] = (*dataService)[k]
			k--
		}
		(*dataKendaraan)[k+1] = kunciKendaraan
		(*dataPemilik)[k+1] = kunciPemilik
		(*dataService)[k+1] = kunciService
	}
	fmt.Println("Data berhasil diurutkan berdasarkan Tahun Servis!")
}

func statistikServis(dataService Tab_Riwayat_servis, i int) {
	fmt.Println("=== STATISTIK SERVIS ===")

	var jenisCount [NMAX]string
	var count [NMAX]int
	nJenis := 0

	var j int
	for j = 0; j < i; j++ {
		found := false
		var k int
		for k = 0; k < nJenis; k++ {
			if jenisCount[k] == dataService[j].jenis {
				count[k]++
				found = true
				break
			}
		}
		if !found {
			jenisCount[nJenis] = dataService[j].jenis
			count[nJenis] = 1
			nJenis++
		}
	}

	fmt.Println("Kategori Kerusakan:")
	for j = 0; j < nJenis; j++ {
		fmt.Println(jenisCount[j], ":", count[j], "kali")
	}

	var bulanCount [13]int
	for j = 0; j < i; j++ {
		if dataService[j].bulan >= 1 && dataService[j].bulan <= 12 {
			bulanCount[dataService[j].bulan]++
		}
	}

	fmt.Println("Jumlah Servis per Bulan:")
	namaBulan := []string{"", "Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"}
	for j = 1; j <= 12; j++ {
		if bulanCount[j] > 0 {
			fmt.Println(namaBulan[j], ":", bulanCount[j], "kendaraan")
		}
	}
}
